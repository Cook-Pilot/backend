# VPS 배포용. cp .env.example .env 후 값을 채운다.
# .env 는 절대 커밋하지 않는다 (.gitignore 등록됨).

# --- PostgreSQL ---
POSTGRES_DB=cookpilot
POSTGRES_USER=cookpilot
# 반드시 교체. 예: openssl rand -base64 24
POSTGRES_PASSWORD=CHANGE_ME

# --- 앱 ---
APP_PORT=8080

# --- Watchtower ---
# GHCR 폴링 주기(초). 기본 300 = 5분. 너무 짧게 잡으면 레지스트리 rate limit 위험.
WATCHTOWER_INTERVAL=300
